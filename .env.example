# Reddit API credentials. Create a Reddit "script" app at:
# https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=common-ground-revealer/0.1 by u_YOUR_USERNAME

# Gemini API key from Google AI Studio.
GEMINI_API_KEY=

# Safety defaults.
DRY_RUN=true
MAX_DAILY_POSTS=10
SCAN_INTERVAL_MINUTES=30

# Optional tuning.
DATABASE_PATH=common_ground_bot.sqlite3
GEMINI_MODEL=gemini-3.5-flash
MINIMUM_CONFIDENCE=0.78
MINIMUM_RELEVANCE=0.70
MIN_SECONDS_BETWEEN_LIVE_POSTS=60
SEARCH_LIMIT_PER_SUBREDDIT=15
MAX_CANDIDATES_PER_SCAN=25
CANDIDATE_COMMENT_LIMIT=30
MIN_THREAD_COMMENTS=20
MIN_THREAD_SCORE=0
REDDIT_SORT=comments
REDDIT_TIME_FILTER=day
TIMEZONE=UTC

# Optional override. Comma-separated subreddit names, with or without r/.
# SUBREDDITS=changemyview,NeutralPolitics,moderatepolitics,PoliticalDiscussion,AskConservatives,AskALiberal,worldnews,news,geopolitics,economics,politics,canada

# Optional override for Reddit search.
# SEARCH_QUERY=democrat OR republican OR liberal OR conservative OR "public opinion" OR poll OR survey OR policy OR voters
